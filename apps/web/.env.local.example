# Copy this to .env.local and fill in your keys.
# NEVER commit .env.local to git.

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=     # server-side only — never expose to client

ANTHROPIC_API_KEY=
MAPBOX_TOKEN=
GOOGLE_PLACES_API_KEY=
# Google Custom Search — same Google Cloud project as Places.
# Enable "Custom Search API", then create a CSE at cse.google.com and grab the ID.
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
